import base64

# A sample piece of data (e.g., an image bit or a password)
data = "User:Asha_2024"

# 1. Base64 Encoding (Used in Emails/APIs)
encoded_b64 = base64.b64encode(data.encode()).decode()
print(f"Base64 Encoded: {encoded_b64}")

# 2. Hex Encoding (Used in binary data representation)
encoded_hex = data.encode().hex()
print(f"Hex Encoded: {encoded_hex}")

# 3. URL Encoding (Used in web addresses)
import urllib.parse
encoded_url = urllib.parse.quote(data)
print(f"URL Encoded: {encoded_url}")
